programa {
  funcao inicio() {

 inteiro numero
 logico ehpositivo

escreva("Digite um numero: ") 
leia(numero)
 
 ehpositivo = numero > 0
 ehnegativo = < 0
 ehzero == numero 0 

 escreva("Esse numero é positivo? ",ehpositivo)
 escreva("\nEsse numero é negativo? ",ehnegativo )
 escreva("\nEsse numero é zero? ",ehzero)

  }
  







  
}
  
}  
} 
