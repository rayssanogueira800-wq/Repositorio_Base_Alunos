programa {
  funcao inicio() {
   real horas_trabalhadas
   real valor_hora
   real salario

   escreva("Quantas horas voce trabalha: ")
   leia(horas_trabalhadas)

   escreva("Quanto é a hora trabalhada: ")
   leia(valor_hora)

   salario = horas_trabalhadas * valor_hora

   escreva("O seu salario é: ", salario) 
  }
}
