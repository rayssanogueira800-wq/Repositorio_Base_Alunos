programa {
  funcao inicio() {
    real cateto1
    real cateto2
    real hipotenusa

    escreva("digite o primeiro cateto: ")
    leia(cateto1)

    escreva("digite o segundo cateto: ")
    leia(cateto2)

    hipotenusa = cateto1 * cateto1 + cateto2 * cateto2 

    escreva("a hipotenusa ao quadrado é: ",hipotenusa)


  }
}
