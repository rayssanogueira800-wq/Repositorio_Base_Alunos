programa {
  funcao inicio() {

   //verificar se o número é positivo 
   //verificar se o número é negativo 
   //verificar se o número é zero 

    inteiro numero 
     logico ehpositivo  

      escreva("Digite um número: ")
      leia( nuemero ) 

      ehpositivo = numero > 0

      escreva("Esse número é positivo? ";ehpositivo)
  }
}
